{
  "name": "learn-chinese-ai",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "pnpm --filter @learn-chinese-ai/web dev",
    "dev:admin": "pnpm --filter @learn-chinese-ai/admin dev",
    "dev:api": "pnpm --filter @learn-chinese-ai/api dev",
    "build": "turbo run build",
    "build:web": "pnpm --filter @learn-chinese-ai/web build",
    "build:admin": "pnpm --filter @learn-chinese-ai/admin build",
    "build:api": "pnpm --filter @learn-chinese-ai/api build",
    "lint": "turbo run lint",
    "lint:web": "pnpm --filter @learn-chinese-ai/web lint",
    "lint:admin": "pnpm --filter @learn-chinese-ai/admin lint",
    "lint:api": "pnpm --filter @learn-chinese-ai/api lint",
    "lint:fix": "turbo run lint -- --fix",
    "typecheck": "turbo run typecheck",
    "typecheck:web": "pnpm --filter @learn-chinese-ai/web typecheck",
    "typecheck:admin": "pnpm --filter @learn-chinese-ai/admin typecheck",
    "typecheck:api": "pnpm --filter @learn-chinese-ai/api typecheck",
    "test": "turbo run test",
    "test:api": "pnpm --filter @learn-chinese-ai/api test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "check:web": "pnpm lint:web && pnpm typecheck:web && pnpm build:web",
    "check:admin": "pnpm lint:admin && pnpm typecheck:admin && pnpm build:admin",
    "check:api": "pnpm lint:api && pnpm typecheck:api && pnpm test:api",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm format",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.6",
    "@typescript-eslint/eslint-plugin": "^8.42.0",
    "@typescript-eslint/parser": "^8.42.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "turbo": "^2.0.14",
    "typescript": "^5.9.2",
    "shadcn": "^4.7.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
